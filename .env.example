# Required — Anthropic Messages API
ANTHROPIC_API_KEY=

# Required — Turso libsql (extractions table, rate-limit rows)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Required — basic auth on /admin
ADMIN_PASSWORD=

# Optional — dual-write to traces.zeroindex.ai
TRACE_PACK_URL=
TRACE_PACK_TOKEN=

# Optional — model override (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=

# Optional — daily extraction cap per IP (defaults to 25). Set high locally for
# testing; leave at the default in production.
RATE_LIMIT_PER_DAY=

# Optional — salt for hashing client IPs into rate-limit buckets (raw IPs are
# never stored). Falls back to a baked-in default; set a real secret in prod.
RATE_LIMIT_SALT=

# Optional — local dev override
# TURSO_DATABASE_URL=file:./local.db
